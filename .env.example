OPENAI_API_KEY=
# Optional: model for script generation when "Web search" is on (default gpt-4.1). See OpenAI Responses API + web_search.
OPENAI_SCRIPT_WEB_MODEL=
# Google Gemini API key for scene image generation (Nano Banana / gemini-3.1-flash-image-preview)
NANO_BANANA_API_KEY=
# Optional: Gemini scene image size — 512, 1K (default), 2K, or 4K. Video editor / API can override per request.
# GEMINI_IMAGE_SIZE=1K
ELEVENLABS_API_KEY=
# Optional default ElevenLabs voice id for TTS (API / video editor when none selected)
# ELEVENLABS_DEFAULT_VOICE_ID=

# Remotion Studio iframe on /studio (default http://localhost:3001 — matches pnpm dev)
# NEXT_PUBLIC_REMOTION_STUDIO_URL=http://localhost:3001
