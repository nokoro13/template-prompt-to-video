OPENAI_API_KEY=
# Optional: model for script generation when "Web search" is on (default gpt-4.1). See OpenAI Responses API + web_search.
OPENAI_SCRIPT_WEB_MODEL=
# Google Gemini API key for scene image generation (Nano Banana / gemini-3.1-flash-image-preview)
NANO_BANANA_API_KEY=
# Optional: Gemini scene image size — 512, 1K (default), 2K, or 4K. Video editor / API can override per request.
# GEMINI_IMAGE_SIZE=1K
ELEVENLABS_API_KEY=
# Optional default ElevenLabs voice id for TTS (API / video editor when none selected)
# ELEVENLABS_DEFAULT_VOICE_ID=

# Remotion Studio iframe on /studio (default http://localhost:3001 — matches pnpm dev)
# NEXT_PUBLIC_REMOTION_STUDIO_URL=http://localhost:3001

# --- Auth (Clerk) ---
# Create an application at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Billing (Clerk) ---
# Enable Billing in Clerk Dashboard → Billing Settings, then create user plans
# with slugs "basic" ($99.99/mo) and "premium" ($199.99/mo). Both unlock the app;
# credit allowances per plan are configured in lib/billing/config.ts.
# @see https://clerk.com/docs/nextjs/guides/billing/for-b2c

# --- Database (Neon Postgres) ---
# Neon connection string — used by Drizzle ORM
DATABASE_URL=

# --- Object storage (Cloudflare R2) ---
# Required for production blob storage (images, audio, renders). Without R2, files stay on local disk.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional: custom domain or r2.dev URL for public reads
# R2_PUBLIC_BASE_URL=

# --- Remotion Lambda (video export) ---
# REMOTION_AWS_ACCESS_KEY_ID=
# REMOTION_AWS_SECRET_ACCESS_KEY=
# REMOTION_AWS_REGION=us-east-2
# REMOTION_FUNCTION_NAME=remotion-render-4-0-448-mem2048mb-disk2048mb-120sec
# REMOTION_SERVE_URL=https://remotionlambda-xxxxx.s3.us-east-2.amazonaws.com/sites/clipng/index.html
# After changing src/ compositions, redeploy: npx remotion lambda sites create src/index.ts --site-name=clipng --region us-east-2
# Days to keep finished MP4 exports in R2 (default 7). Exports also invalidate when the project is edited.
# EXPORT_RETENTION_DAYS=7
